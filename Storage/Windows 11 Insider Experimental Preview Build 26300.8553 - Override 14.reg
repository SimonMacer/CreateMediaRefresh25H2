## Available flags
# Show Braille settings by default. ViVetool ID: 61795378 (CFR RKey: 1706533518)
# Braille settings are now always visible since HID protocol support is baked into windows and is planned on being shipped inbox.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\1706533518]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Alternate taskbar positions. ViVetool ID: 59213768 (CFR RKey: 2439114895)
# Allows the taskbar to be positioned on any side of the screen (bottom, top, left, or right), providing greater flexibility in how users arrange their workspaces.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\2439114895]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Smaller Taskbar. ViVetool ID: 61090762 (CFR RKey: 2486810255)
# Enables a more compact taskbar experience with smaller icons and reduced height, giving users more available screen space for their apps.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\2486810255]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Screen Tint. ViVetool ID: 60662124 (CFR RKey: 3643655310)
# Screen Tint feature applies color tint effects to the display to reduce eye strain and improve viewing comfort.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\3643655310]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Smarter app suggestions in Share (apps toggle on the Settings > System > Share). ViVetool ID: 58353646 (CFR RKey: 3701475983)
# The share experience now suggests relevant apps and allows installation directly from the share dialog, reducing workflow interruptions and improving productivity. This experience is now available for both work (AAD) and personal accounts, with controls to manage app recommendations.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\3701475983]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Magnifier Simplification. ViVetool ID: 62049423 (CFR RKey: 536320655)
# Simplifies Magnifier by disabling touch bars for panning by default, providing a cleaner and less distracting magnified view on touchscreen devices.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\536320655]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Windows Search Box. ViVetool ID: 61610780 (CFR RKey: 945399438)
# Files and apps more reliably appear ahead of web suggestions when your content is a stronger match.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\945399438]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Improved Magnifier quick settings access. ViVetool ID: 61635110 (CFR RKey: 1285269134)
# Magnifier now gives you more control over how you zoom. You can type an exact zoom percentage directly in the magnifier toolbar to land on precisely the level you need.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\1285269134]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Pause updates on your schedule. ViVetool ID: 61410885 (CFR RKey: 2322836622)
# Use a calendar to pause updates until a selected date. Extend the pause at any time to align with your schedule.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\2322836622]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# New Windows Insider Program experience, including Advanced Options to choose version and Feature Platforms releases. ViVetool ID: 61157505 (CFR RKey: 34583695)
# Updates the Windows Insider Program settings experience with clearer channel definitions and improved navigation. Provides more transparency into available preview features and simplifies build selection.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\34583695]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Faster reopening of restartable apps. ViVetool ID: 60958073 (CFR RKey: 4062558862)
# Previously open apps reopen faster after a restart following updates, reducing disruption and enabling a quicker return to prior activity.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\4062558862]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Touchpad Enhancements. ViVetool ID: 58429071 (CFR RKey: 527566991)
# Add new gesture based functionality to touchpad in Settings, including scroll and zoom speed, automatic scrolling, accelerated scrolling, and single-finger scrolling.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\527566991]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Free upgrade path to Windows 11 Pro Education for K-12. ViVetool ID: 52298135 (CFR RKey: 778879631)
# Windows Insiders in K–12 education environments can now experience a seamless upgrade path from Windows 11 Home to Windows 11 Pro Education edition—at no additional cost. Please note: This upgrade is one-way only. Reverting to Windows Home is not supported without a clean OS reinstall.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\778879631]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Fluid Dictation Language Expansion in Voice Typing. ViVetool ID: 60901381 (CFR RKey: 184532110)
# Uses Windows Voice Typing fluid dictation in Spanish & French to automatically correct grammar, punctuation, and filler words as you speak.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\184532110]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Fluid Dictation Language Expansion in Voice Access. ViVetool ID: 59887882 (CFR RKey: 365812878)
# Uses Windows Voice Access fluid dictation in Spanish & French to automatically correct grammar, punctuation, and filler words as you speak.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\365812878]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

# Consistent solid (donut) spinners across key Windows scenarios. ViVetool ID: 59728252 (CFR RKey: 4172144782)
# Introduces a unified solid (donut) spinner with matching status text across key Windows experiences like boot, sign-in, restart, shutdown, and updates.
[HKEY_LOCAL_MACHINE\SYSTEM\ControlSet001\Control\FeatureManagement\Overrides\14\4172144782]
"EnabledState"=dword:00000002
"EnabledStateOptions"=dword:00000000

